# Docker Compose env file — copy to `.env` and fill in real values.
#   cp .env.example .env
#
# This file is read by `docker compose` for ${VAR} interpolation in
# docker-compose.yml. It is NOT read by the Spring app directly — Compose
# expands these into real environment variables, which Spring then binds.
# The real `.env` is gitignored; this `.example` is committed as documentation.

# JWT signing key. REQUIRED — compose refuses to start without it.
# Generate a fresh 256-bit key:  openssl rand -hex 32
JWT_SECRET=

# PostgreSQL credentials. POSTGRES_PASSWORD is REQUIRED.
# NOTE: the password is applied only when the DB volume is first created.
# To change it on an existing volume:  docker compose down -v  (wipes dev data).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# OpenRouter API key for Spring AI (OpenAI-compatible). REQUIRED — app fails at
# startup if unset. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPTIONAL — override the model. Must support tool-calling. Free `:free` models
# work but can be rate-limited (429). Default: openai/gpt-oss-20b:free
#OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Public URL of the frontend, used to build links emailed to users
# (e.g. team-invite accept). Defaults to the Vite dev server if unset.
APP_BASE_URL=http://localhost:5173

# Redis (report cache + public-endpoint rate limiter).
# Local app runs read these; in Docker the backend reaches Redis at the compose
# service name (see SPRING_DATA_REDIS_HOST in docker-compose.yml), so these two
# are the LOCAL-run values only. No password in dev.
REDIS_HOST=localhost
REDIS_PORT=6379

# Host-published ports. Container-internal ports are fixed; these only change how
# your host machine reaches each container. Bump one if it clashes locally.
# NOTE: KAFKA_PORT is also written into the broker's advertised listener, so
# changing it here is enough — the two stay in sync.
POSTGRES_PORT=5433
MAILPIT_SMTP_PORT=1026
MAILPIT_UI_PORT=8026
BACKEND_PORT=8100
KAFKA_PORT=9092
KAFKA_UI_PORT=8090

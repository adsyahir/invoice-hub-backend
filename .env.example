# Docker Compose env file — copy to `.env` and fill in real values.
#   cp .env.example .env
#
# This file is read by `docker compose` for ${VAR} interpolation in
# docker-compose.yml. It is NOT read by the Spring app directly — Compose
# expands these into real environment variables, which Spring then binds.
# The real `.env` is gitignored; this `.example` is committed as documentation.

# JWT signing key. REQUIRED — compose refuses to start without it.
# Generate a fresh 256-bit key:  openssl rand -hex 32
JWT_SECRET=

# PostgreSQL credentials. POSTGRES_PASSWORD is REQUIRED.
# NOTE: the password is applied only when the DB volume is first created.
# To change it on an existing volume:  docker compose down -v  (wipes dev data).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Public URL of the frontend, used to build links emailed to users
# (e.g. team-invite accept). Defaults to the Vite dev server if unset.
APP_BASE_URL=http://localhost:5173
